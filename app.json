{
  "expo": {
    "name": "app-that-helps-me-re",
    "slug": "app-that-helps-me-re",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-mof.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-mof.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-mof.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "scheme": "appthathelpsmere",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a9ab6dc5-9484-4eda-9d4c-bef6fa81ebeb"
      }
    },
    "owner": "tc42"
  }
}